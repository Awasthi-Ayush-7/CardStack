# ============================================================
# Backend environment variables
# Set these in Vercel: Project → Settings → Environment Variables
# ============================================================

# PostgreSQL connection string (required)
# Get one free from: https://neon.tech, https://supabase.com, or https://railway.app
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — use a strong random string (required)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-64-char-string

# Token expiry in hours (optional, default: 24)
JWT_EXPIRE_HOURS=24

# CORS — comma-separated list of allowed frontend origins (required for production)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Frontend URL used in password reset emails (required if using email)
FRONTEND_URL=https://your-app.vercel.app

# ============================================================
# Email — password reset (optional)
# If not set, reset links are printed to server logs instead
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Frontend environment variables
# Set REACT_APP_API_URL in Vercel so the build picks it up
# ============================================================

# Points the React app at the /api route on the same Vercel domain
REACT_APP_API_URL=/api
