# Copy this file to .env and fill in your keys.
# Never commit .env — it is listed in .gitignore.

# JWT (change to a long random string in production)
JWT_SECRET=change-me-in-production

# Google Gemini — free AI analysis (250 req/day free tier)
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# SerpAPI — live Google Flights cash prices for accurate CPP (250 searches/month free)
# Sign up at https://serpapi.com
SERPAPI_API_KEY=

# AviationStack — IATA airport code lookup (500 req/month free)
# Sign up at https://aviationstack.com
AVIATIONSTACK_API_KEY=

# Anthropic Claude — optional paid fallback for AI analysis
# Only needed if Gemini is unavailable
ANTHROPIC_API_KEY=

# Database (defaults to local SQLite for development)
# DATABASE_URL=postgresql://user:pass@localhost/cardstack
